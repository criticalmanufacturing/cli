      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "properties": {
          "args": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "string"
            },
            "description": "Gets or sets the arguments."
          },
          "command": {
            "type": [
              "string",
              "null"
            ],
            "description": "Gets or sets the command."
          },
          "workingDirectory": {
            "type": [
              "object",
              "null"
            ],
            "description": "Gets or sets the working directory."
          },
          "environmentVariables": {
            "type": [
              "object",
              "null"
            ],
            "additionalProperties": {
              "type": "string"
            },
