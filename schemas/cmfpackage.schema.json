    },
    "targetLayer": {
      "type": [
        "string",
        "null"
      ],
      "description": "Gets or sets the target layer, which means the container in which the packages contents should be installed.\nThis is used when the package is installed using Environment Manager and ignored when it is installed using Deployment Framework."
    },
