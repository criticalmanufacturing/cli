        "Reporting",
        "ExportedObjects",
        "Database",
        "None",
        "IoTData",
        "Tests",
        "SecurityPortal",
        "ProductDatabase",
        "Grafana"
      ]
    },
    "targetDirectory": {
      "type": [
        "string",
        "null"
      ],
